generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SubscriptionPlan {
  starter
  growth
  pro
  agency
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  incomplete
}

enum CreditLedgerReason {
  trial
  usage
  reset
  purchase
}

enum ImageJobStatus {
  queued
  processing
  completed
  failed
}

model User {
  id                     String              @id @default(cuid())
  email                  String              @unique
  password_hash          String
  stripe_customer_id     String?             @unique
  stripe_subscription_id String?             @unique
  stripe_price_id        String?
  stripe_product_id      String?
  billing_plan           SubscriptionPlan?
  billing_status         SubscriptionStatus?
  billing_email          String?
  current_period_start   DateTime?
  current_period_end     DateTime?
  cancel_at_period_end   Boolean             @default(false)
  credits_included       Int                 @default(0)
  credits_remaining      Int                 @default(0)
  credits_used           Int                 @default(0)
  credits_reset_at       DateTime?
  created_at             DateTime            @default(now())
  updated_at             DateTime            @updatedAt
  sites                  ConnectedSite[]
  subscriptions          Subscription[]
  credit_ledger          CreditLedger[]
  image_jobs             ImageJob[]
  processed_images       ProcessedImage[]

  @@map("optivra_users")
}

model ConnectedSite {
  id             String   @id @default(cuid())
  user_id        String
  domain         String
  api_token_hash String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, domain])
  @@unique([api_token_hash])
  @@index([user_id])
  @@map("connected_sites")
}

model Subscription {
  id                     String             @id @default(cuid())
  user_id                String
  plan                   SubscriptionPlan
  status                 SubscriptionStatus
  current_period_start   DateTime?
  current_period_end     DateTime
  stripe_subscription_id String?            @unique
  stripe_price_id        String?
  stripe_product_id      String?
  cancel_at_period_end   Boolean            @default(false)
  credits_included       Int                @default(0)
  credits_remaining      Int                @default(0)
  credits_used           Int                @default(0)
  billing_email          String?
  credits_reset_at       DateTime?
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt
  user                   User               @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@map("subscriptions")
}

model StripeEvent {
  id              String    @id @default(cuid())
  stripe_event_id String    @unique
  event_type      String
  type            String?
  processed_at    DateTime?
  raw_event       Json?
  account_id      String?
  status          String    @default("received")
  error_message   String?
  created_at      DateTime  @default(now())

  @@index([event_type])
  @@index([account_id])
  @@index([status])
  @@map("stripe_events")
}

model CreditLedger {
  id              String             @id @default(cuid())
  user_id         String
  account_id      String?
  change_amount   Int
  amount          Int?
  balance_after   Int?
  reason          CreditLedgerReason
  source          String?
  description     String?
  stripe_event_id String?
  idempotency_key String?            @unique
  created_at      DateTime           @default(now())
  user            User               @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([account_id])
  @@index([reason])
  @@index([source])
  @@index([stripe_event_id])
  @@map("credit_ledger")
}

model ImageJob {
  id                        String           @id @default(cuid())
  user_id                   String
  original_url              String
  processed_url             String?
  status                    ImageJobStatus   @default(queued)
  original_image_hash       String?
  duplicate_of_job_id       String?
  original_storage_path     String?
  processed_storage_path    String?
  debug_cutout_storage_path String?
  seo_metadata              Json?
  original_uploaded_at      DateTime?
  processed_uploaded_at     DateTime?
  debug_cutout_uploaded_at  DateTime?
  storage_cleanup_after     DateTime?
  credit_deducted_at        DateTime?
  created_at                DateTime         @default(now())
  updated_at                DateTime         @updatedAt
  user                      User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  processed_images          ProcessedImage[]

  @@index([user_id])
  @@index([user_id, original_image_hash])
  @@index([status])
  @@index([storage_cleanup_after])
  @@map("image_jobs")
}

model ProcessedImage {
  id            String    @id @default(cuid())
  image_job_id  String
  user_id       String
  processed_url String
  storage_path  String?
  seo_metadata  Json?
  created_at    DateTime  @default(now())
  cleanup_after DateTime?
  image_job     ImageJob  @relation(fields: [image_job_id], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([image_job_id])
  @@index([user_id])
  @@index([cleanup_after])
  @@map("processed_images")
}
