{
  "name": "optivra-backend",
  "version": "1.0.0",
  "description": "Production-ready Node.js backend for the Optivra SaaS platform.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc && node -e \"require('node:fs').accessSync('dist/server.js')\"",
    "render:build": "npm install && npx prisma generate && npx prisma migrate deploy && npm run build",
    "start": "node scripts/start.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:status": "prisma migrate status",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test:analytics": "tsx scripts/check-analytics-rules.ts",
    "test:image-audit": "tsx scripts/check-image-audit-scoring.ts",
    "test:image-audit-routes": "tsx scripts/check-image-audit-routes.ts",
    "test:image-audit-start-auth": "tsx scripts/check-image-audit-start-auth.ts",
    "test:image-audit-recommendation-queue": "tsx scripts/check-image-audit-recommendation-queue.ts",
    "test:image-audit-large-e2e": "tsx scripts/check-image-audit-large-e2e.ts",
    "test:image-studio-ux": "tsx scripts/check-image-studio-ux-redesign.ts",
    "test:image-studio-scan-results": "tsx scripts/check-image-studio-scan-results-regression.ts",
    "test:attention-images": "tsx scripts/check-attention-image-proxy.ts",
    "test:audit-queue": "tsx scripts/check-audit-queue-rules.ts",
    "test:wordpress-api-url": "php scripts/check-wordpress-api-url.php",
    "test:csp": "tsx scripts/check-csp-rules.ts",
    "test:plugin-downloads": "tsx scripts/check-plugin-download-workflow.ts",
    "test:billing-credits": "tsx scripts/check-billing-credit-config.ts",
    "test:free-credit-grant": "tsx scripts/check-free-credit-grant-idempotency.ts",
    "test:review-demo": "tsx scripts/check-review-demo-integrity.ts",
    "test:preserve-debug": "node scripts/check-preserve-debug.js",
    "test:preserve-architecture": "tsx scripts/check-preserve-architecture.ts",
    "test:product-protection": "tsx scripts/check-product-protection-validation.ts",
    "test:image-pipeline": "node scripts/check-image-pipeline-rules.js",
    "test:image-processing-matrix": "tsx scripts/check-image-processing-matrix.ts"
  },
  "keywords": [
    "optivra",
    "saas",
    "express",
    "typescript",
    "prisma",
    "supabase"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@imgly/background-removal-node": "^1.4.5",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.104.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "nodemailer": "^8.0.7",
    "sharp": "^0.34.5",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": "20.x"
  }
}
