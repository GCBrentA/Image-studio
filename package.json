{
  "name": "optivra-backend",
  "version": "1.0.0",
  "description": "Production-ready Node.js backend for the Optivra SaaS platform.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc && node -e \"require('node:fs').accessSync('dist/server.js')\"",
    "render:build": "npm install && npx prisma generate && npx prisma migrate deploy && npm run build",
    "start": "node scripts/start.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:status": "prisma migrate status",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test:preserve-debug": "node scripts/check-preserve-debug.js"
  },
  "keywords": [
    "optivra",
    "saas",
    "express",
    "typescript",
    "prisma",
    "supabase"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@imgly/background-removal-node": "^1.4.5",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.104.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "sharp": "^0.34.5",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": "20.x"
  }
}
