{
  "name": "optivra-image-studio-shopify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:worker": "tsx watch server/worker/index.ts",
    "build": "tsc --noEmit && vite build",
    "start": "tsx server/index.ts",
    "worker": "tsx server/worker/index.ts",
    "typecheck": "tsc --noEmit",
    "migrate:sql": "echo \"Run supabase/migrations SQL against Supabase before deploy\""
  },
  "dependencies": {
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/polaris": "^13.9.5",
    "@vitejs/plugin-react": "^4.3.4",
    "cookie": "^1.0.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "vite": "^6.0.6"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": "20.x"
  }
}
